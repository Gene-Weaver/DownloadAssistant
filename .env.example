# GBIF account for the FULL Darwin Core download (ACQUIRE SEARCH → complete
# archive + DOI, past the 100k offset wall). Copy this file to ".env" and fill it
# in. ".env" is gitignored and never committed; nothing is written to settings.
#
# IMPORTANT: use your GBIF ACCOUNT USERNAME, not your email address. The download
# API uses HTTP Basic auth with username:password; a browser login is NOT enough
# (GBIF's website token is rejected by api.gbif.org).
#
# Don't have an account? Register free at https://www.gbif.org/user/profile

GBIF_USER=your_gbif_username
GBIF_PASS=your_gbif_password
GBIF_EMAIL=you@example.org
